rt":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"History of Data","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"tO3QKmhqIR"}],"identifier":"history-of-data","label":"History of Data","html_id":"history-of-data","implicit":true,"key":"dfT49hMF7B"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"A characteristic of data is that it must be measured or recorded. Hence, data is as old as the oldest human systems for recording data. One of the earliest remnants of such an endeavor is the Ishango bone, estimated to be around 20,000 years old ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"J6MohU89nt"},{"type":"cite","kind":"narrative","label":"pletser_ishango_1999","identifier":"pletser_ishango_1999","children":[{"type":"text","value":"Pletser & Huylebrouck (1999)","key":"JanuZ7IibA"}],"enumerator":"1","key":"inT62s8cJS"},{"type":"text","value":". This artifact, displaying systematic notches grouped in blocks, resembles an ancient tally stick, hinting at our ancestral drive to count or record.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"CYG0qeuMxy"}],"key":"x0U0w6y1p5"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"The very essence of data collection goes hand in hand with the birth of writing and symbolic representation. Interestingly, the oldest instances of these systems were not used to create elaborate letters, prose, or captivating stories. Instead, they were wielded for what may seem mundane today: collecting and managing taxes and outstanding services. This fits a saying that is usually linked to Benjamin Franklin: ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"FFQuHTk0zy"},{"type":"emphasis","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"“...in this world nothing can be said to be certain, except death and taxes”","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"tafZr6DEfk"}],"key":"ZuXCS4dmFR"},{"type":"text","value":" ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"U7XCiMni4f"},{"type":"footnoteReference","identifier":"death-taxes","label":"death-taxes","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"enumerator":"1","key":"tgLK5lXeFe"}],"key":"rAPK5CFlNc"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"While data has been collected and used for millennia, the term ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"Eg7zrsgEzP"},{"type":"emphasis","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"“data”","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"PsRQD4CMvQ"}],"key":"NPqO0eBY1m"},{"type":"text","value":" itself is relatively nascent. Originating from the Latin word ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"ZOW2KyHwVL"},{"type":"emphasis","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"datum","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"sWALAfTh70"}],"key":"QQ5N2bBhjC"},{"type":"text","value":", which means “given”, the English adoption of ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"r94AOqEdIA"},{"type":"emphasis","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"data","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"IIlvbc29aO"}],"key":"ofnXMebKW6"},{"type":"text","value":" is believed to have been in the 1640s. The evolution of the term underscores our ever-growing understanding and reliance on the structured representation of knowledge.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"gO9Y63j69B"}],"key":"jFcqhPO1X3"},{"type":"heading","depth":2,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Data Types","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"O0YH2itgL6"}],"identifier":"data-types","label":"Data Types","html_id":"data-types","implicit":true,"key":"vyU6eW4tQI"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Before we dive deeper into how to acquire and process data, we first need to know some fundamental terms and their distinctions.","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"v01BLb4Fiq"}],"key":"Cw4mHVz619"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"strong","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Structured vs. Unstructured Data","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"hxjwgup367"}],"key":"KYVzPWNPRc"}],"key":"vEeSlIvX5C"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"At the crux of data storage and management lie two primary categories: structured and unstructured data.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"lpZEep8QzP"}],"key":"C7pdxBuJN8"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"Structured data","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"WJMbYHCfZJ"}],"key":"TxLrct6ay3"},{"type":"text","value":" is organized into a defined schema or format. It’s easy to search, manipulate, and analyze because of its systematic arrangement, often in rows and columns. Examples include relational databases and CSV files, but you can also just think of this as any data that you could meaningfully display in a table.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"N3AsSp5kkG"}],"key":"lrF3TL8zQD"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"Conversely, ","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"DTWYGkXle6"},{"type":"emphasis","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"unstructured data","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"dLakytepJ9"}],"key":"QtDHGxZBk2"},{"type":"text","value":" doesn’t simply fit into a table. Or, we could say that this data has no specific form or model. As an important consequence, such data is typically harder to classify and analyze using traditional methods. Text documents, videos, and social media posts are common examples of unstructured data.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"c9GvyAyUdK"}],"key":"yp6QMyIxGm"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"strong","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"Feature vs. Data Points and the Dimensionality of Data","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"IE1o5ckAbQ"}],"key":"FYvbJlHEGi"}],"key":"xqalO5rvxs"},{"type":"paragraph","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"When we speak of data, especially in tables, we refer to ","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"f3qpqD7ZwV"},{"type":"emphasis","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"features","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"PDfmU7MIVq"}],"key":"GECpoeY59p"},{"type":"text","value":", which are, depending on the field and context, also called ","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"Q5ZoQ86S7D"},{"type":"emphasis","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"variables","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"lmd6s7t7M3"}],"key":"t7tkHzDm3K"},{"type":"text","value":" or ","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"fglEpMGjza"},{"type":"emphasis","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"attributes","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"oTC8PVr2Ka"}],"key":"gh9C3f4IqY"},{"type":"text","value":", and ","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"c36BbSS1g0"},{"type":"emphasis","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"data points","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"xqg4b2lOjX"}],"key":"PorWMKhtpT"},{"type":"text","value":". Features are the distinct attributes or properties of the dataset. In tabular data, these often appear as columns. For instance, in a table cataloging books, features might include “Title”, “Author”, and “Publication Year”.","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"QJYQ9feotB"}],"key":"bayYk2xy40"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"On the other hand, ","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"TpvlK4Z2w2"},{"type":"emphasis","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"data points","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"Zgnw9r28O1"}],"key":"rqJs1esUY8"},{"type":"text","value":" are individual pieces of information, often represented as rows in tabular data. For example, each book listed in the aforementioned table would be a data point.","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"jmzRYT1YGV"}],"key":"i91jMgHVdh"},{"type":"paragraph","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"The concept of dimensionality arises from the number of features. A table with three features is 3-dimensional, while a table with 15 features is 15-dimensional. Understanding dimensionality is crucial, especially in domains like machine learning, where high dimensionality can lead to challenges such as the “curse of dimensionality”.","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"n6DdGcLF6c"}],"key":"hR6rpLilzJ"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"strong","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Data vs. Metadata","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"nStGgmTauy"}],"key":"SXGwkpWK6n"}],"key":"hEtUuIaxOT"},{"type":"paragraph","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"While ","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"w0NQXHQY2l"},{"type":"emphasis","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"data","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"xYxPLSf6ft"}],"key":"sBXR01xV6t"},{"type":"text","value":" represents the core information we aim to analyze or utilize, ","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"j6nL8H9Eb2"},{"type":"emphasis","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"metadata","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"S1kmBzvbt4"}],"key":"ACb3YvJwYJ"},{"type":"text","value":" is the information about this data. It describes the data’s context, quality, condition, origin, and other characteristics. If data is a book, metadata is the blurb on the back, providing insights about its content, author, and publication details.","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"FSdDDXFiJl"}],"key":"DaKsA7llSD"},{"type":"paragraph","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"strong","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Categorical vs. Numerical Data","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"ZIwqUA3Kgg"}],"key":"ABmeuIN6h1"}],"key":"rTtoOQw7BO"},{"type":"paragraph","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"When it comes to data analysis, we often distinguish two main types of ","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"MJvy2VdrOL"},{"type":"emphasis","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"data","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"WT4lx6TXsi"}],"key":"ouRN5EbLwq"},{"type":"text","value":": categorical and numerical.","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"A2MkexeAuq"}],"key":"eYrrgUKOyR"},{"type":"paragraph","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"text","value":"Categorical data","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"w5jXYP4tQf"}],"key":"Mlt0DdcurF"},{"type":"text","value":" refers to data that falls into distinct groups or categories without any natural order or ranking among them. These categories are defined by  qualitative characteristics that describe or identify traits or  attributes. For example, the color of a shirt—whether it is blue, red,  or green—represents categorical data.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"sAiIUwG8ka"}],"key":"OmuF2rY9sM"},{"type":"paragraph","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"Numerical data","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"SGoMKJh6AX"}],"key":"NoEwVYUHry"},{"type":"text","value":", as the name suggests, encompasses data represented by numbers, which can be further  categorized into two subtypes: discrete and continuous. Discrete data are countable quantities like the number of books on a shelf, while  continuous data involve measurements and can represent any value within a range, such as the height of a person or the weight of an object.","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"jGDNI5HhH2"}],"key":"fQNpl5ZXNc"},{"type":"paragraph","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"strong","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Understanding Data Scales","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"XxM8QKwWmf"}],"key":"a202IFqBPc"}],"key":"VGJcSAAFZl"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"Very often, the distinction between ","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"iKsHEAK708"},{"type":"emphasis","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"categorical","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"EFsb2obi5m"}],"key":"uZsRkPoavZ"},{"type":"text","value":" and ","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"iGTHKZcqZ0"},{"type":"emphasis","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"numerical","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"oQhXQuEzyQ"}],"key":"l665z8rqLl"},{"type":"text","value":" data is not good enough. Helpful for later steps in a data science process are the following data scales:","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"w3V5Tv7QUI"}],"key":"xA4uZ2pauA"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":51,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"children":[{"type":"text","value":"Nominal Scale","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"key":"iIhxmAWkTW"}],"key":"HvDZh59NJV"},{"type":"text","value":": This scale is used for categorizing data without implying any order. It applies to categorical data where the emphasis is on distinguishing between items based on names or labels. Typical examples are gender, country, ethnicity, or eye color.","position":{"start":{"line":51,"column":1},"end":{"line":51,"column":1}},"key":"AEK8ZI4xhR"}],"key":"EVP1d5nSGW"}],"key":"e64sE5xA2t"},{"type":"listItem","spread":true,"position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"text","value":"Ordinal Scale","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"EWsjNUT880"}],"key":"xDp0FdPAIB"},{"type":"text","value":": Here, data is still categorical but with an inherent order or ranking among the categories. However, the differences between these ranks are not equal or standardized. A common example would be a rating system such as: poor, fair, good, excellent. Here, the scale implies order but not the magnitude of difference between adjacent rankings.","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"fTCfEThOHH"}],"key":"vAYsBejHVS"}],"key":"J4LONly1Se"},{"type":"listItem","spread":true,"position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"children":[{"type":"text","value":"Interval Scale","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"fLfufnn0xR"}],"key":"cybz5M0Q5h"},{"type":"text","value":": This scale applies to numerical data that has equal intervals between values but no true zero point, making ratios meaningless. Temperature measured in Celsius is a classic example, where the difference between 10°C and 20°C is the same as between 20°C and 30°C, such that we can talk about a 10°C difference in both cases. But 0°C does not denote an absence of temperature. As a consequence, 5°C is ","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"H9wOB9ktpM"},{"type":"strong","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"children":[{"type":"text","value":"not","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"pexvIgSULa"}],"key":"VznA9y4y49"},{"type":"text","value":" five times as warm as 1°C.","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"XGXcqrvyeK"}],"key":"IqXG41vo9z"}],"key":"rDBqwYE0yj"},{"type":"listItem","spread":true,"position":{"start":{"line":54,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"Ratio Scale","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"Io2apWtmbS"}],"key":"x5GNFQ8EmE"},{"type":"text","value":": Ratio scales are similar to interval scales in that they feature equal spacing between values but also include a true zero point, allowing for meaningful ratios. Examples include measurements of length, weight, and age. A 10-year-old bottle of wine is indeed two times older than a 5-year-old bottle.","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"SOojWRGCWj"}],"key":"paGGn5cLVz"}],"key":"nWX4gEOWeL"}],"key":"LLqdhIZziT"},{"type":"table","position":{"start":{"line":56,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"tableRow","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"tableCell","header":true,"position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"Scale Type","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"jyjUAvxEtf"}],"key":"BDlMpX0dm7"},{"type":"tableCell","header":tru